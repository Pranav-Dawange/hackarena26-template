# ── Flask ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key
FLASK_DEBUG=true
HOST=0.0.0.0
PORT=5000

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/signalsevak
MONGO_DB_NAME=signalsevak

# ── CORS (comma-separated origins; use * for development) ───────────────────
CORS_ORIGINS=*

# ── Alert Thresholds ─────────────────────────────────────────────────────────
RSSI_ALERT_THRESHOLD=-80
PACKET_LOSS_THRESHOLD=20.0
NODE_OFFLINE_TIMEOUT=60

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/signalsevak.log
